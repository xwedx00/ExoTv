# ─────────────────────────────────────────────────────────────────────────────
# ExoTv environment template — copy to `.env` (or just run the app; all optional).
#
# ExoTv has NO required env vars and NO secrets. It is fully self-contained:
#   • Metadata    → AniList GraphQL (public)
#   • Anime source → in-app scraper (consumet) at /api/anime/*
#   • Manga source → MangaDex public API at /api/manga/*
#   • CORS/HLS     → in-app proxy at /api/proxy
#   • Persistence  → browser localStorage (no database, no accounts)
# ─────────────────────────────────────────────────────────────────────────────

# Google Analytics measurement ID (optional). Blank = analytics disabled.
NEXT_PUBLIC_GA_ID=

# Anime provider fallback order (optional, comma-separated). Blank = default order.
# Example: ANIME_PROVIDERS=animeunity,animesaturn,hianime,animepahe,animekai
ANIME_PROVIDERS=
