# ─────────────────────────────────────────────────────────────────────────────
# ExoTv environment
#
# ExoTv is fully self-contained: AniList (metadata) + an in-app scraper backend
# (anime via consumet, manga via MangaDex) + browser localStorage (no accounts).
# There are NO required variables and NO secrets — every value below is optional.
# This file is intentionally safe to commit.
# ─────────────────────────────────────────────────────────────────────────────

# Google Analytics measurement ID (optional). Leave blank to disable analytics.
NEXT_PUBLIC_GA_ID=

# Anime source provider order (optional, comma-separated). Overrides the default
# fallback order the in-app scraper tries. Leave blank to use the default.
# Example: ANIME_PROVIDERS=animeunity,animesaturn,hianime,animepahe,animekai
ANIME_PROVIDERS=
